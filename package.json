{
  "name": "video-making",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "dev": "pnpm --dir vibe-motion-app run dev",
    "prepare": "pnpm run prepare:app",
    "prepare:app": "pnpm run install:app && pnpm --dir vibe-motion-app run remotion:ensure-browser && pnpm run motion:stack",
    "preview:dev": "pnpm --dir vibe-motion-app run preview:dev",
    "studio": "pnpm --dir vibe-motion-app run remotion:studio",
    "remotion:studio": "pnpm --dir vibe-motion-app run remotion:studio",
    "remotion:compositions": "pnpm --dir vibe-motion-app run remotion:compositions",
    "remotion:render": "pnpm --dir vibe-motion-app run remotion:render",
    "remotion:render:demo": "pnpm --dir vibe-motion-app run remotion:render:demo",
    "lint": "pnpm --dir vibe-motion-app run lint",
    "verify": "pnpm --dir vibe-motion-app run verify",
    "build": "pnpm --dir vibe-motion-app run build",
    "install:app": "pnpm --dir vibe-motion-app install",
    "motion:stack": "node .codex/skills/create-vibe-motion/scripts/detect_motion_stack.mjs",
    "slidev:help": "slidev --help",
    "slidev:dev": "slidev slides/slidev/rich-media-demo.md --port 3030",
    "slidev:build": "slidev build slides/slidev/rich-media-demo.md --out ../exports/site",
    "slidev:export:pdf": "slidev export slides/slidev/rich-media-demo.md --output slides/exports/rich-media-demo.pdf",
    "slidev:export:pptx": "slidev export slides/slidev/rich-media-demo.md --format pptx --output slides/exports/rich-media-demo.pptx",
    "slidev:export:png": "slidev export slides/slidev/rich-media-demo.md --format png --output slides/exports/rich-media-demo",
    "slidev:install-browser": "playwright install chromium",
    "media:help": "node tools/polish-media.mjs help",
    "media:inspect": "node tools/polish-media.mjs inspect",
    "media:trim": "node tools/polish-media.mjs trim",
    "media:mp4": "node tools/polish-media.mjs mp4",
    "media:gif": "node tools/polish-media.mjs gif",
    "media:frames": "node tools/polish-media.mjs frames",
    "media:still": "node tools/polish-media.mjs still",
    "media:thumbs": "node tools/polish-media.mjs thumbs",
    "darwin:help": "node tools/darwin-motion.mjs help",
    "darwin:init": "node tools/darwin-motion.mjs init",
    "darwin:score": "node tools/darwin-motion.mjs score",
    "darwin:capture": "node tools/darwin-motion.mjs capture",
    "darwin:queue": "node tools/darwin-motion.mjs queue",
    "darwin:log": "node tools/darwin-motion.mjs log",
    "darwin:report": "node tools/darwin-motion.mjs report",
    "gitflow": "node tools/git-flow.mjs",
    "gitflow:help": "node tools/git-flow.mjs help",
    "gitflow:doctor": "node tools/git-flow.mjs doctor",
    "gitflow:list": "node tools/git-flow.mjs list",
    "gitflow:start": "node tools/git-flow.mjs start",
    "gitflow:checkpoint": "node tools/git-flow.mjs checkpoint",
    "gitflow:ready": "node tools/git-flow.mjs ready",
    "gitflow:promote": "node tools/git-flow.mjs promote",
    "gitflow:publish": "node tools/git-flow.mjs publish",
    "skills:list": "npx skills list --json",
    "skills:add:nuwa": "npx skills add alchaincyf/nuwa-skill --yes",
    "skills:restore": "npx skills experimental_install"
  },
  "devDependencies": {
    "@slidev/cli": "^52.15.0",
    "@slidev/theme-default": "^0.25.0",
    "playwright-chromium": "^1.59.1"
  }
}
