{
  "name": "vibe-motion-app",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  },
  "scripts": {
    "postinstall": "node scripts/remotion-ensure-browser.mjs",
    "preview:dev": "vite",
    "remotion:ensure-browser": "node scripts/remotion-ensure-browser.mjs",
    "remotion:studio": "node scripts/remotion-cli.mjs studio",
    "remotion:bundle": "node scripts/remotion-cli.mjs bundle",
    "remotion:compositions": "node scripts/remotion-cli.mjs compositions",
    "remotion:render": "node scripts/remotion-render.mjs",
    "remotion:render:demo": "REMOTION_OUTPUT=out/scaffold-demo-defaults-transparent.mov REMOTION_PROPS_FILE=shared/project/render-presets/default.json pnpm run remotion:render",
    "deploy:edgeone:url": "EDGEONE_OPEN=0 node scripts/open-edgeone-pages.mjs",
    "deploy:edgeone:open": "node scripts/open-edgeone-pages.mjs",
    "deploy:edgeone": "pnpm run remotion:bundle && pnpm run deploy:edgeone:open",
    "dev": "node scripts/dev-workbench.mjs",
    "build": "pnpm run deploy:edgeone",
    "lint": "eslint .",
    "verify": "pnpm run lint && pnpm run remotion:compositions"
  },
  "dependencies": {
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@lottiefiles/dotlottie-web": "^0.71.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@remotion/captions": "4.0.438",
    "@remotion/cli": "4.0.438",
    "@remotion/media-utils": "4.0.438",
    "@remotion/paths": "4.0.438",
    "@remotion/shapes": "4.0.438",
    "@remotion/tailwind-v4": "4.0.438",
    "@remotion/transitions": "4.0.438",
    "@rive-app/react-canvas": "^4.28.3",
    "@tailwindcss/vite": "^4.1.4",
    "animejs": "^4.3.6",
    "culori": "^4.0.2",
    "d3": "^7.9.0",
    "gsap": "^3.15.0",
    "maath": "^0.10.8",
    "matter-js": "^0.20.0",
    "motion": "^12.38.0",
    "pixi.js": "^8.18.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "remotion": "4.0.438",
    "simplex-noise": "^4.0.3",
    "tailwindcss": "^4.1.4",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/react": "^19.0.10",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.22.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "globals": "^16.0.0",
    "vite": "^6.3.1"
  }
}
